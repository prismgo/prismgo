# DB_MAX_OPEN_CONNS=30
# DB_MAX_IDLE_CONNS=10
# DB_CONN_MAX_LIFETIME=1h
# DB_CONN_MAX_IDLE_TIME=10m

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=false
SESSION_ENCODING=
SESSION_CONNECTION=default
SESSION_PREFIX=prismgo_session
SESSION_COOKIE=prismgo_session
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE_COOKIE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_FILES=storage/framework/sessions
SESSION_LOCK_SECONDS=10
SESSION_LOCK_WAIT_SECONDS=10

QUEUE_CONNECTION=sync
QUEUE_ENCODING=
QUEUE_FAILED_DRIVER=memory
QUEUE_FAILED_STORE=default
QUEUE_FAILED_PREFIX=prismgo_queue
QUEUE_FAILED_TTL=0
QUEUE_BATCHING_DRIVER=memory
QUEUE_BATCHING_STORE=default
QUEUE_BATCHING_PREFIX=prismgo_queue
QUEUE_BATCHING_TTL=0
QUEUE_RESTART_CACHE=
QUEUE_RESTART_KEY=prismgo:queue:restart
SYNC_QUEUE=default

# DATABASE_QUEUE=default
# DATABASE_QUEUE_TABLE=jobs

CACHE_STORE=memory
CACHE_ENCODING=
CACHE_PREFIX=prismgo_cache
CACHE_LIMITER_DRIVER=memory
CACHE_MEMORY_PREFIX=memory
CACHE_MEMORY_TTL=0
CACHE_MEMORY_CLEANUP_INTERVAL=60
CACHE_MEMORY_EVENTS=true
CACHE_FILE_PREFIX=file
CACHE_FILE_PATH=storage/framework/cache/data
CACHE_FILE_LOCK_PATH=storage/framework/cache/locks
CACHE_FILE_TTL=0
CACHE_FILE_EVENTS=true
CACHE_FAILOVER_STORES=redis,memory
CACHE_FAILOVER_EVENTS=true
CACHE_LOCK_PREFIX=locks
CACHE_LOCK_RETRY_SLEEP_MS=50
CACHE_FLEXIBLE_REFRESH_TIMEOUT=30

PRISMGO_ENCODING=msgpack

FILESYSTEM_DISK=local
FILESYSTEM_CLOUD=oss
FILESYSTEM_SIGNING_KEY=
FILESYSTEM_LOCAL_ROOT=storage/app/private
FILESYSTEM_LOCAL_URL=
FILESYSTEM_LOCAL_VISIBILITY=private
FILESYSTEM_LOCAL_SERVE=true
FILESYSTEM_PUBLIC_ROOT=storage/app/public
FILESYSTEM_PUBLIC_URL=http://localhost:8080/storage
FILESYSTEM_PUBLIC_VISIBILITY=public
FILESYSTEM_PUBLIC_SERVE=true

REDIS_CLIENT=go
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=
REDIS_MAIN_DB=1
REDIS_CACHE_DB=0

