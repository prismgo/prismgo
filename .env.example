APP_NAME=Prismgo
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080

APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en

SERVER_HOST=127.0.0.1
SERVER_PORT=8080
SERVER_TIMEOUT=15
SERVER_READ_TIMEOUT=15s
SERVER_READ_HEADER_TIMEOUT=5s
SERVER_WRITE_TIMEOUT=30s
SERVER_IDLE_TIMEOUT=60s
SERVER_SHUTDOWN_TIMEOUT=15s
SERVER_MAX_HEADER_BYTES=1048576
SERVER_MAX_MULTIPART_MEMORY=33554432
SERVER_TRUSTED_PROXIES=
SERVER_CLIENT_IP_HEADERS=X-Forwarded-For,X-Real-IP
SERVER_ACCESS_LOG=true
SERVER_EXCEPTION_HANDLER=true

LOG_CHANNEL=stack
APP_LOGGER_LEVEL=debug
APP_LOGGER_FORMATTER=line
APP_LOGGER_FILE=storage/logs/app.log
ERROR_LOGGER_DRIVER=daily
ERROR_LOGGER_LEVEL=warn
ERROR_LOGGER_FORMATTER=line
ERROR_LOGGER_FILE=storage/logs/error/error.log
STDERR_LOGGER_LEVEL=debug
STDERR_LOGGER_FORMATTER=line
STDOUT_LOGGER_LEVEL=debug
STDOUT_LOGGER_FORMATTER=line

DATABASE_CONNECTION=sqlite
DATABASE_NAME=storage/database.sqlite

# DATABASE_CONNECTION=mysql
# DATABASE_DRIVER=mysql
